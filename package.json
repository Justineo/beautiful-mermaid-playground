{
  "name": "beautiful-mermaid-playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:themes": "run-s generate:themes:raw generate:themes:format",
    "generate:themes:raw": "run-p generate:themes:official:raw generate:themes:unofficial:raw",
    "generate:themes:official:raw": "pnpm exec tsx scripts/generate-beautiful-themes.ts",
    "generate:themes:unofficial:raw": "pnpm exec tsx scripts/generate-unofficial-themes.ts",
    "generate:themes:format": "run-p generate:themes:official:format generate:themes:unofficial:format",
    "generate:themes:official:format": "oxfmt --config .oxfmtrc.json src/generated/beautifulThemes.ts",
    "generate:themes:unofficial:format": "oxfmt --config .oxfmtrc.json src/generated/unofficialThemes.ts",
    "sync:official-samples": "run-s sync:official-samples:raw sync:official-samples:format",
    "sync:official-samples:raw": "pnpm exec tsx scripts/sync-official-samples.ts",
    "sync:official-samples:format": "oxfmt --config .oxfmtrc.json src/data/officialSamples.ts",
    "dev": "run-s generate:themes dev:raw",
    "dev:raw": "vite",
    "build": "run-s generate:themes \"build:raw {@}\" --",
    "build:raw": "run-p type-check:raw \"build-only:raw {@}\" --",
    "preview": "vite preview",
    "build-only": "run-s generate:themes \"build-only:raw {@}\" --",
    "build-only:raw": "vite build",
    "test:unit": "node --test --import tsx ./test/**/*.test.ts",
    "prepare": "lefthook install",
    "type-check": "run-s generate:themes type-check:raw",
    "type-check:raw": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt --config .oxfmtrc.json src/"
  },
  "dependencies": {
    "@shikijs/core": "4.0.2",
    "@shikijs/engine-javascript": "4.0.2",
    "@shikijs/langs": "4.0.2",
    "@shikijs/monaco": "4.0.2",
    "@shikijs/themes": "4.0.2",
    "@vercel/analytics": "^2.0.0",
    "@vueuse/core": "14.2.1",
    "apca-w3": "^0.1.9",
    "beautiful-mermaid": "1.1.3",
    "lucide-vue-next": "^1.0.0",
    "monaco-editor": "0.55.1",
    "overlayscrollbars": "2.15.1",
    "shiki": "4.0.2",
    "vue": "3.6.0-beta.10"
  },
  "devDependencies": {
    "@kong-ui-public/monaco-editor": "0.22.6",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.3.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "1.62.0",
    "eslint-plugin-vue": "~10.9.0",
    "lefthook": "2.1.6",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "tsx": "^4.20.6",
    "typescript": "~6.0.0",
    "vite": "8.0.10",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
